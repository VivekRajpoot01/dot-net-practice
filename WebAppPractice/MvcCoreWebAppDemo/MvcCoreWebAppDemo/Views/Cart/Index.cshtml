@model List<CartItem>

<h2>Your Cart</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        @{
            double grandTotal = 0;
        }

        @foreach (var item in Model)
        {
            var total = item.Product.Price * item.Quantity;
            grandTotal += total;

            <tr>
                <td>@item.Product.Name</td>
                <td>₹ @item.Product.Price</td>
                <td>@item.Quantity</td>
                <td>₹ @total</td>
            </tr>
        }
    </tbody>
</table>

<h4 class="text-end">Grand Total: ₹ @grandTotal</h4>